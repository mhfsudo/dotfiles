# Example file for the ~/.ssh/config when using 2 ssh keys

Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519
    IdentifiesOnly yes
    AddKeysToAgent yes
    UserKeychain yes

Host gitlab.com
    HostName gitlab.com
    User git
    IdentityFile ~/.ssh/id_rsa
    IdentifiesOnly yes
    AddKeysToAgent yes
    UserKeychain yes

Host *
    AddKeysToAgent yes
    UserKeychain yes